store:
  name: "Your Store Name"
  url: "https://yourstore.com"
  niche: "Your Niche"

# Define your available LLMs here
models:
  fast:
    provider: "groq"
    name: "llama3-70b-8192"
    temperature: 0.1
  smart:
    provider: "openai"
    name: "gpt-4-turbo"
    temperature: 0.3
  creative:
    provider: "gemini"
    name: "gemini-1.5-pro"
    temperature: 0.7

# Assign models to specific agent roles
agents:
  product_specialist:
    model_key: "fast"
    verbose: true
    allow_delegation: false
  growth_strategist:
    model_key: "smart"
    verbose: true
    allow_delegation: true
  brand_scout:
    model_key: "creative"
    verbose: true
    allow_delegation: false
